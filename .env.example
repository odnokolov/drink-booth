# Скопируй в .env и заполни. В Vercel — Environment Variables для Production.

# Airtable (сервер, /api/contacts.js)
AIRTABLE_BASE_ID=
AIRTABLE_API_KEY=
AIRTABLE_TABLE=Contacts

# Google Apps Script — POST контактов (сервер)
GOOGLE_SCRIPT_URL=

# Тот же URL для чтения настроек стенда в браузере (VITE_*)
VITE_GOOGLE_SCRIPT_URL=

# Опционально: ограничить CORS для /api/contacts
# ALLOWED_ORIGIN=https://your-domain.vercel.app
